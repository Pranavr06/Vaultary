{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/health.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/((?!api).*)",
            "dest": "app.py"
        }
    ]
}